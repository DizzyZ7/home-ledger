# PostgreSQL
POSTGRES_DB=homeledger
POSTGRES_USER=homeledger
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://homeledger:change-me-local-only@db:5432/homeledger
JWT_SECRET_KEY=replace-with-a-long-random-value-before-public-deployment
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
